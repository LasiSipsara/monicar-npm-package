{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "@app/monicar/(.*)": "<rootDir>/../libs/monicar/src/$1",
    "@app/monicar": "<rootDir>/../libs/monicar/src"
  }
}